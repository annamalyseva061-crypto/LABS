using System;

namespace LinearEquation
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = "Решение линейного уравнения ax + b = 0";
            
            Console.WriteLine("Уравнение: ax + b = 0 (a ≠ 0)\n");
            
            Console.Write("Введите коэффициент a (a ≠ 0): ");
            double a = double.Parse(Console.ReadLine());
            
            if (a == 0)
            {
                Console.WriteLine("Ошибка: a не может быть равно 0!");
            }
            else
            {
                Console.Write("Введите коэффициент b: ");
                double b = double.Parse(Console.ReadLine());
                
                double x = -b / a;
                Console.WriteLine($"\nРешение: x = {x:F2}");
                Console.WriteLine($"Проверка: {a} * ({x:F2}) + {b} = {a * x + b:F2}");
            }
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
