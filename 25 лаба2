using System;

namespace DigitSumProduct
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = "Работа 2. Сумма и произведение цифр четырёхзначного числа";
            
            Console.Write("Введите четырёхзначное число: ");
            int number = int.Parse(Console.ReadLine());
            
            if (number < 1000 || number > 9999)
            {
                Console.WriteLine("Ошибка: число должно быть четырёхзначным (от 1000 до 9999)");
            }
            else
            {
                int thousands = number / 1000;           
                int hundreds = (number / 100) % 10;      
                int tens = (number / 10) % 10;           
                int ones = number % 10;                  
                
                int sum = thousands + hundreds + tens + ones;
                int product = thousands * hundreds * tens * ones;
                
                Console.WriteLine($"\nЧисло: {number}");
                Console.WriteLine($"Цифры: {thousands} {hundreds} {tens} {ones}");
                Console.WriteLine($"Сумма цифр: {thousands} + {hundreds} + {tens} + {ones} = {sum}");
                Console.WriteLine($"Произведение цифр: {thousands} * {hundreds} * {tens} * {ones} = {product}");
            }
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
