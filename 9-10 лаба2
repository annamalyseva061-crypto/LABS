using System;

namespace RoundingNumbers
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = "Работа 2. Округление чисел";
            
            double number = 123.456789;
            double e = Math.E;
            
            Console.WriteLine($"Число: {number}");
            Console.WriteLine($"С точностью до сотых: {Math.Round(number, 2)}");
            Console.WriteLine($"\nЧисло e: {e}");
            Console.WriteLine($"Число e с точностью до десятых: {Math.Round(e, 1)}");
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
