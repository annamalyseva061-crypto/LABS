using System;

namespace RingArea
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = " Площадь кольца";
            
            Console.WriteLine("Формула: S = π(R² - r²)\n");
            
            Console.Write("Введите внешний радиус R: ");
            double R = double.Parse(Console.ReadLine());
            
            Console.Write("Введите внутренний радиус r: ");
            double r = double.Parse(Console.ReadLine());
            
            if (r > R)
            {
                Console.WriteLine("Ошибка: внутренний радиус не может быть больше внешнего!");
            }
            else
            {
                double area = Math.PI * (R * R - r * r);
                Console.WriteLine($"\nПлощадь кольца: {area:F2}");
            }
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
